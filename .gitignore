compiler/pascal26
compiler/pascal26-managed
compiler/compiler
compiler/*.o
compiler/*.ppu
test/hello
# Compiled test binaries: extensionless ELF built from test/*.pas (and .npy).
# Ignore everything named test_* under test/, then keep the sources (anything
# with an extension) and any subdirectories.
test/test_*
!test/test_*.*
!test/test_*/
# ...but never keep object files (the !test_*.* rule would otherwise re-add them).
test/*.o
test/*.ppu
/tmp/
__pycache__/
*.swp
*.swo
.qoder/
.idea/
.vscode/
devdocs/developer/historic/user-rambling/
thesises/
.antigravitycli/
external/
test/gui/helloworld/lib/
test/gui/helloworld/backup/
test/gui/helloworld/helloworld
*.lps
*.map
library_candidates/

# Compiled example binaries: extensionless ELF built next to <name>.pas
# (examples/adventure/adventure, examples/life/life, ...). Ignore one-level
# files in each example dir, then keep sources/data (anything with an
# extension) and subdirectories (scenes/, esp32 build trees, ...).
examples/*/*
!examples/*/*.*
!examples/*/*/
# Build artifacts anywhere under examples (esp32 IDF output, etc). The .map
# re-ignore is needed because the !examples/*/*.* keep-rule above would
# otherwise re-add the linker maps that the global *.map rule excludes.
examples/**/*.o
examples/**/*.elf
examples/**/*.map
examples/**/*.a
examples/**/*.bin
# The whole IDF build tree (CMake caches, ninja logs, bootloader ...) — one
# stray `git add <example dir>` must never sweep it in again.
examples/esp32/*/build/

# `make demos` output (built demo binaries; DEMO_OUT, per-checkout, never committed).
/build/
# Release build output (tools/release.sh assembles dist/ each run; never commit it).
/dist/
# Docs website build output (tools/build_docs_site.py assembles it each run;
# published via the pages.yml workflow, never committed).
/_site/
# Stray top-level build outputs (e.g. a misfired `gcc -o` that wrote literal "-o").
/-o
/-o.map

# Generated by ./install.sh — local wrapper + IDE link (absolute paths; per-checkout).
/pxx
/eliah

# Claude editor metadata
.claude/

devdocs/progress/BOARD.html
# tstate dashboard pages are generated artifacts (twatch_web.py --static),
# regenerated from the committed .tsv/.ndjson/.json data on every idle bench.
# Committing them makes every writer (dev, each watcher host) collide on a
# rebase — the data is the source of truth, the html is a local/served view.
devdocs/progress/tstate/*.html
.testmgr/
fred.txt
