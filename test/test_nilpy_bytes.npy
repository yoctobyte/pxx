# bytearray v1 — the mapping core. Oracle: CPython — running this file with
# python3 must produce byte-identical output to the compiled binary.
#
# Deliberately NOT here, because both need the shared parser's subscript
# grammar or keyword arguments, which Track N must not edit: slices
# (`b[a:c]`, `b[a:c] = other`) and `int.to_bytes(...)`. See
# feature-nilpy-bytes-and-slices.

b = bytearray(4)
print(len(b))
print(b[0])
print(b[3])

b[0] = 65
b[1] = 66
b[3] = 255
print(b[0])
print(b[1])
print(b[2])
print(b[3])

# a negative index counts from the end, as for str and list
print(b[-1])
print(b[-4])

# bytes() copies, so writing through the original does not change the copy
c = bytes(b)
b[0] = 1
print(c[0])
print(b[0])
print(len(c))

big = bytearray(1024)
print(len(big))
print(big[1023])
