# f-strings. Oracle: CPython — running this file with python3 must produce
# byte-identical output to the compiled binary.
#
# Covers plain {expr} holes, the {{ }} escapes, the !r / !s conversions, and
# the format-spec subset: [<|>] [0] [width] [d|x|X|o|b|s]. A spec outside that
# grammar halts naming itself rather than being ignored — a spec decides what
# is PRINTED, so silently dropping one produces wrong output.

b = True
n = 42
d = 1.5
s = "hi"

print(f"v={n}!")
print(f"{s} has {n} apples")
print(f"no holes here")
print(f"")
print(f"{{literal braces}}")
print(f"{n}")
print(f"a{n}b{s}c")

# every scalar spelling Python uses, including the two the shared str()
# intrinsic gets wrong (a string prints its pointer, a bool prints 1)
print(f"{b} {n} {d} {s}")
print(f"{not b}")

# expressions, not just names
print(f"{n + 1} and {n * 2}")


def twice(a: int) -> int:
    return a * 2


print(f"call {twice(3)} done")

xs = [1, 2, 3]
print(f"len {len(xs)}")


class P:
    def __init__(self) -> None:
        self.name = "zed"
        self.n = 3


p = P()
print(f"{p.name}/{p.n}")

# a dict subscript inside a hole arrives as a Variant
q = {"k": 9}
print(f"{q['k']}")

# !r quotes a string and leaves every other type alone; !s is plain str()
print(f"{s!r} {n!r} {b!r} {d!r}")
print(f"{s!s}")
r = {"k": "vv"}
print(f"{r['k']!r}")

# PASSTHROUGH: the expander rewrites the whole source, so everything that is
# NOT an f-string has to come through untouched — a comment containing a quote
# or a brace, a string containing a '#', escaped quotes, a backslash, and an
# 'f' that is only the start of an identifier.
# a comment with a quote ' and a brace { and an f" that is not a string
plain = "text with # not a comment"
single = 'single {braces} kept'
esc = "escaped \" quote"
back = "backslash \\ end"
prefix = "abc"
print(plain)
print(single)
print(esc)
print(back)
print(prefix)

# format specs: base, zero padding, width, alignment
v = 255
w = 7
print(f"{v:x} {v:X} {v:d}")
print(f"{w:05d} {v:04x}")
print(f"{w:b} {w:o}")
print(f"0x{v:x}")
print(f"[{s:5}] [{w:5}] [{w:<5}]")
print(f"{-5:04d}")
