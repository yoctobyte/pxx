# Full SQLite CRUD round-trip driven from Nil Python importing sqlite3 directly.
# Exercises out-param return-lifting for sqlite3_open and sqlite3_prepare_v2,
# along with auto-conversion of char* return values to managed strings for
# sqlite3_column_text.
import sqlite3

db = sqlite3_open("/tmp/test_nilpy_sqlite_crud.db")
sqlite3_exec(db, "DROP TABLE IF EXISTS t;", 0, 0, 0)
sqlite3_exec(db, "CREATE TABLE t(id INTEGER, name TEXT);", 0, 0, 0)
sqlite3_exec(db, "INSERT INTO t VALUES(1, 'alice');", 0, 0, 0)
sqlite3_exec(db, "INSERT INTO t VALUES(2, 'bob');", 0, 0, 0)

stmt = sqlite3_prepare_v2(db, "SELECT id, name FROM t ORDER BY id;", -1)
while sqlite3_step(stmt) == SQLITE_ROW:
    print(sqlite3_column_int(stmt, 0), sqlite3_column_text(stmt, 1))

sqlite3_finalize(stmt)
sqlite3_close(db)
