# Regression: feature-nilpy-exception-message.
# print(e) and str(e) of a caught built-in exception show its message (CPython
# str(e) semantics), not the instance pointer.
def main() -> None:
    try:
        raise ValueError("bad value")
    except Exception as e:
        print(e)
        print(str(e))
        print("got: " + str(e))
    try:
        raise RuntimeError("boom")
    except Exception as e:
        print(e)

main()
