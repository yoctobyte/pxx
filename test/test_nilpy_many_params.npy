def weighted(a: int, b: int, c: int, d: int, e: int, f: int, g: int, h: int) -> int:
    return a + 2 * b + 3 * c + 4 * d + 5 * e + 6 * f + 7 * g + 8 * h

def tail(a: int, b: int, c: int, d: int, e: int, f: int, g: int, h: int) -> int:
    return h

def five(a: int, b: int, c: int, d: int, e: int) -> int:
    return a + 2 * b + 3 * c + 4 * d + 5 * e

def six(a: int, b: int, c: int, d: int, e: int, f: int) -> int:
    return f * 10 + e

print(five(1, 2, 3, 4, 5))
print(six(1, 2, 3, 4, 5, 6))
print(weighted(1, 1, 1, 1, 1, 1, 1, 1))
print(weighted(1, 2, 3, 4, 5, 6, 7, 8))
print(tail(10, 20, 30, 40, 50, 60, 70, 80))
