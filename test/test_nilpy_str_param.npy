# Regression: bug-nilpy-str-param-length-index — a str-annotated parameter
# must behave as a full string inside the body.
#
# Ported to 0-BASED indexing 2026-07-19 (bug-nilpy-str-index-off-by-one): this
# file was originally written against Pascal's 1-based subscripts, so it
# asserted "ab"[1] == "a". Python says "b". The indices below are now Python's,
# which is what the uforth corpus requires.
# Face 1: Length(param); Face 2: param[i] indexing; Face 3: scanning loop
# combining both (was an IR codegen ICE / variant-tag miscompile);
# plus `-> None` procedure defs and calling them as statements.

def flen(line: str) -> int:
    n = Length(line)
    return n

def fidx(line: str) -> str:
    c = line[1]        # Python: the SECOND character
    return c

def tok(line: str, want: int) -> str:
    n = Length(line)
    i = 0
    idx = 0
    cur = ""
    out = ""
    while i <= n:
        c = " "
        if i < n:
            c = line[i]
        if c == " ":
            if cur != "":
                idx = idx + 1
                if idx == want:
                    out = cur
                cur = ""
        else:
            cur = cur + c
        i = i + 1
    return out

def shout(msg: str) -> None:
    print(msg + "!")

print(flen("ab"))
print(fidx("ab"))
print(tok("ab cd ef", 2))
shout("ok")
