b = (10).to_bytes(8, "little", signed=True)
print(len(b))
print(b[0])
print(b[1])
print(int.from_bytes(b, "little", signed=True))
n = -2
c = n.to_bytes(8, 'little', signed=True)
print(c[0])
print(c[7])
print(int.from_bytes(c, 'little', signed=True))
d = (255).to_bytes(2, "little", signed=False)
print(d[0])
print(d[1])
print(int.from_bytes(d, "little", signed=False))
e = (-1).to_bytes(1, "little", signed=True)
print(int.from_bytes(e, "little", signed=True))
print(int.from_bytes(e, "little", signed=False))
