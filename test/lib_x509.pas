program lib_x509;
{ X.509 DER parsing + certificate-signature verification (M5). Three self-signed
  certs (RSA / ECDSA-P256 / Ed25519) parse, and their self-signatures verify.
  ECDSA verify is exercised by lib_ecdsa_p256 (slow); here it is parse-only. }
uses x509;

procedure SayBool(const tag: string; b: Boolean);
begin
  if b then writeln(tag, '=ok') else writeln(tag, '=FAIL');
end;

function Nyb(c: Char): Integer;
begin
  if (c >= '0') and (c <= '9') then Nyb := Ord(c) - Ord('0')
  else Nyb := Ord(c) - Ord('a') + 10;
end;

function Hx(const h: AnsiString): AnsiString;
var i, hi, lo: Integer;
begin
  Result := ''; i := 1;
  while i + 1 <= Length(h) do
  begin hi := Nyb(h[i]); lo := Nyb(h[i+1]); Result := Result + Chr((hi shl 4) or lo); i := i + 2; end;
end;

const
  RC = '';
  ED = '';
  EC = '';

var cr, ce, cd: TCert;
begin
  cr := X509Parse(Hx(RC));
  ce := X509Parse(Hx(EC));
  cd := X509Parse(Hx(ED));

  SayBool('rsa-parse', cr.Ok and (Length(cr.PubBits) = 270));
  SayBool('ec-parse',  ce.Ok and (Length(ce.PubBits) = 65));
  SayBool('ed-parse',  cd.Ok and (Length(cd.PubBits) = 32));

  SayBool('rsa-selfverify', X509VerifySig(cr, cr));
  SayBool('ed-selfverify',  X509VerifySig(cd, cd));
end.
