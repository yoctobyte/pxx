program lib_x509;
{ X.509 DER parsing + cert-signature verify + chain validation (M5).
  Self-signed certs (RSA/ECDSA/Ed25519) parse + self-verify; a real CA->leaf
  chain validates incl. issuer link, validity dates, and SAN hostname match. }
uses x509;
procedure SayBool(const tag: string; b: Boolean);
begin if b then writeln(tag, '=ok') else writeln(tag, '=FAIL'); end;
function Nyb(c: Char): Integer;
begin if (c>='0')and(c<='9') then Nyb:=Ord(c)-Ord('0') else Nyb:=Ord(c)-Ord('a')+10; end;
function Hx(const h: AnsiString): AnsiString;
var i,hi,lo: Integer;
begin Result:=''; i:=1; while i+1<=Length(h) do begin hi:=Nyb(h[i]); lo:=Nyb(h[i+1]); Result:=Result+Chr((hi shl 4) or lo); i:=i+2; end; end;
const
  RCHEX = '';
  EDHEX = '';
  ECHEX = '';
  CAHEX = '';
  LEAFHEX = '';
var cr, ce, cd, caC, leafC: TCert;
begin
  cr := X509Parse(Hx(RCHEX)); ce := X509Parse(Hx(ECHEX)); cd := X509Parse(Hx(EDHEX));
  caC := X509Parse(Hx(CAHEX)); leafC := X509Parse(Hx(LEAFHEX));
  SayBool('rsa-parse', cr.Ok and (Length(cr.PubBits) = 270));
  SayBool('ec-parse',  ce.Ok and (Length(ce.PubBits) = 65));
  SayBool('ed-parse',  cd.Ok and (Length(cd.PubBits) = 32));
  SayBool('rsa-selfverify', X509VerifySig(cr, cr));
  SayBool('ed-selfverify',  X509VerifySig(cd, cd));
  SayBool('chain-issuer-link', leafC.Issuer = caC.Subject);
  SayBool('chain-host-exact', X509HostMatch(leafC, 'example.test'));
  SayBool('chain-host-wild',  X509HostMatch(leafC, 'www.example.test'));
  SayBool('chain-host-bad',   not X509HostMatch(leafC, 'evil.test'));
  SayBool('chain-expired-reject', not X509VerifyChain(leafC, caC, '20200101000000', 'example.test'));
  SayBool('chain-badhost-reject', not X509VerifyChain(leafC, caC, '20260625150000', 'evil.test'));
  SayBool('chain-ok', X509VerifyChain(leafC, caC, '20260625150000', 'example.test'));
end.
