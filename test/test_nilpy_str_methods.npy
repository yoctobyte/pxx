# NilPy str methods: .upper() / .lower() (feature-nilpy-str-methods).
#
# Covers every BASE form, because they take different parse routes: an ident
# and a field access are lvalues and go through the shared parser's postfix
# path, while a literal and a call result are not and are picked up by
# PyParseBitOperand's tail. uforth's two real shapes are str(t).upper() and
# t.word.name.upper(), one of each.
#
# ASCII-only case mapping for now: the non-ASCII bytes below must pass through
# UNCHANGED rather than be mangled, which is what makes the emoji-bearing
# uforth word names safe.

def name_of(n: int) -> str:
    return "word" + str(n)

class W:
    def __init__(self, nm: str) -> None:
        self.nm = nm

s = "Hello, World! 123"

print(s.upper())
print(s.lower())

print("MiXeD".upper())
print("MiXeD".lower())

print(str(42).upper())
print(name_of(7).upper())

print(s.upper().lower())
print(s.lower().upper())

w = W("forth")
print(w.nm.upper())

print("".upper())
print("already upper".upper())
print("ALREADY LOWER".lower())
print("digits 0123 and !@# stay".upper())
print("emoji stays >>> ok".upper())

print(s)

# --- precedence: a method binds TIGHTER than +. Hooking the non-lvalue route
# at the additive layer instead of at factor level made this print AB.
print("a" + "b".upper())
print("x" + "  y  ".strip() + "z")

# --- tyChar bases. Python has no char type, but the shared lexer types a
# one-character literal (and s[0]) as tyChar, so these must still be methods.
print("b".upper())
print(" ".isspace())
# s[0].upper() belongs here too, but NilPy string subscripts are still 1-based
# (bug-nilpy-str-index-off-by-one) — adding it now would freeze the wrong answer.

# --- strip family
print("[" + "  padded  ".strip() + "]")
print("[" + "  padded  ".lstrip() + "]")
print("[" + "  padded  ".rstrip() + "]")
print("[" + "".strip() + "]")
print("[" + "   ".strip() + "]")
print("[" + "\t tabbed \n".strip() + "]")

# --- startswith / endswith, including the empty-affix and too-long cases
print("FORTH".startswith("FO"))
print("FORTH".startswith("XX"))
print("FORTH".endswith("TH"))
print("FORTH".endswith("XX"))
print("FORTH".startswith(""))
print("FORTH".endswith(""))
print("FORTH".startswith("FORTHER"))

# --- find: 0-BASED, -1 when absent, 0 for an empty needle
print("FORTH".find("R"))
print("FORTH".find("FORTH"))
print("FORTH".find("zz"))
print("FORTH".find(""))
print("abcabc".find("bc"))
print("abc".find("c"))

# --- isspace: "" is False in CPython (no vacuous truth here)
print("   ".isspace())
print("".isspace())
print(" a ".isspace())
print("\t\n".isspace())

# --- chains mixing the new methods
print("  Mixed  ".strip().upper())
print("  Mixed  ".strip().lower())
print("  a  ".strip().startswith("a"))

# --- 0-based subscripts, now that bug-nilpy-str-index-off-by-one is fixed
print(s[0])
print(s[1])
print(s[-1])
print(s[0].upper())
print(s[-1].upper())
# "abc"[1] — subscripting a LITERAL is a separate gap
# (bug-nilpy-subscript-on-literal), not covered here.

# --- len() on a str as well as a list (feature-nilpy-len-of-str)
print(len("Hello"))
print(len(""))
print(len(["a", "b"]))

# --- join
print(",".join(["a", "b", "c"]))
print("".join(["a", "b", "c"]))
print(" - ".join(["solo"]))
print("[" + ",".join([]) + "]")

# --- split(sep) KEEPS empty fields; split() on whitespace DROPS them.
# Two different algorithms, not a default argument.
print("|".join("a,b,c".split(",")))
print("|".join("a,,b".split(",")))
print(len("".split(",")))
print("|".join("  FORTH  is   fun  ".split()))
print(len("".split()))
print(len("   ".split()))

# --- splitlines: a TRAILING newline yields no final empty field
print("|".join("one\ntwo\nthree".splitlines()))
print(len("a\n".splitlines()))
print(len("".splitlines()))
print(len("a\nb\n".splitlines()))

# --- the uforth scanning idiom, end to end
line = "  DUP SWAP  DROP "
toks = line.split()
print(len(toks))
print("|".join(toks).upper())
i = 0
while i < len(line):
    if line[i] == "D":
        print(i)
    i = i + 1

# unit 4: .rjust(width[, fill]) — right-align, never truncate, default fill is a
# space. The .UFO stdlib's three sites are the whole corpus demand.
print("[" + "7".rjust(3) + "]")
print("7".rjust(3, "0"))
print("abc".rjust(2))
print("[" + "".rjust(4, "*") + "]")
print("x".rjust(0), "y".rjust(1))
wpad = "42"
print(wpad.rjust(5, "."), len(wpad.rjust(5, ".")))
print("a".rjust(3).strip())
